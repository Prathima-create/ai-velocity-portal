# ============================================================
# QC Automation Dashboard — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.template .env

# ─── AWS S3 Configuration ─────────────────────────────────────
# S3 bucket where QC data CSVs are stored
QC_S3_BUCKET=fincom-qc-dashboard-035268397124

# S3 prefix (folder) within the bucket
QC_S3_PREFIX=current/

# AWS credentials (if not using IAM role on EC2)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_DEFAULT_REGION=us-east-1

# ─── SharePoint Configuration ─────────────────────────────────
# SharePoint site URL where the QC audit data lives
QC_SHAREPOINT_SITE=https://amazon.sharepoint.com/sites/Automationhosting

# Server-relative path to the folder containing CSV files
QC_SHAREPOINT_FOLDER=/sites/Automationhosting/Shared Documents/QC_Data

# Direct sharing URL to the SharePoint folder with QC Excel files
QC_SHAREPOINT_FILE_URL=https://amazon.sharepoint.com/:f:/s/Automationhosting/IgCGCoZ4iC-zT7MnpjxNkUTBAT1gotiu5uV1Tzt32YjUAW8?e=SktCYE

# ─── Streamlit Configuration ──────────────────────────────────
# Port for the Streamlit app (default: 8501)
STREAMLIT_SERVER_PORT=8501

# Allow access from any IP on the VPN (not just localhost)
STREAMLIT_SERVER_ADDRESS=0.0.0.0

# ─── Sync Configuration ───────────────────────────────────────
# How often to sync (in minutes) — used by systemd timer or cron
SYNC_INTERVAL_MINUTES=30
